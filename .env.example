# Copy to .env only for local development overrides.
# Keep real secrets and private account data out of git.

POSTGRES_DB=portfolio_options_agent
POSTGRES_USER=portfolio_options_agent
POSTGRES_PASSWORD=replace_with_local_dev_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://portfolio_options_agent:replace_with_local_dev_password@localhost:5432/portfolio_options_agent
