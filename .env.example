# Copy to .env only for local development overrides.
# Keep real secrets and private account data out of git.

APP_NAME=portfolio-options-agent
APP_ENV=local
LOCAL_DEV_ACCESS_TOKEN=replace_with_local_only_random_access_token

# Skyframe connected-smoke controls consumed only by the Vite development proxy.
# Never rename these with a VITE_ prefix or expose them to browser code.
SKYFRAME_FIXTURE_HEADER=private-safe-v1
SKYFRAME_DASHBOARD_STATE=unavailable

POSTGRES_DB=portfolio_options_agent
POSTGRES_USER=portfolio_options_agent
POSTGRES_PASSWORD=replace_with_local_dev_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://portfolio_options_agent:replace_with_local_dev_password@localhost:5432/portfolio_options_agent

# SnapTrade read-only broker sync placeholders.
# Do not commit real SnapTrade credentials.
SNAPTRADE_CLIENT_ID=replace_with_snaptrade_client_id
SNAPTRADE_CONSUMER_KEY=replace_with_snaptrade_consumer_key
SNAPTRADE_ENVIRONMENT=sandbox
SNAPTRADE_SECRET_ENCRYPTION_KEY=replace_with_32_plus_character_local_encryption_key

# FMP economic calendar, market-context, and approved reported-statement placeholder.
# Backend-only. Do not expose this as a VITE_* variable or commit a real key.
# Runtime source lanes remain off unless their backend-only mode is explicitly live.
FMP_API_KEY=replace_with_fmp_api_key

# FRED official macro data placeholder.
# Backend-only. Do not expose this as a VITE_* variable or commit a real key.
# Used for approved economic-awareness data requests through backend adapters.
FRED_API_KEY=replace_with_fred_api_key

# JBlanked economic calendar placeholder.
# Backend-only. Do not expose this as a VITE_* variable or commit a real key.
# Intended for future approved local testing of calendar events/impact labels.
JBLANKED_API_KEY=replace_with_jblanked_api_key
JBLANKED_CALENDAR_BASE_URL=https://www.jblanked.com/news/api
JBLANKED_CALENDAR_SOURCE=forexfactory

# Agentic LLM provider keys (Phase 25A). Backend-only.
# - Do NOT expose these as VITE_* variables and never bundle them to the browser.
# - Do NOT commit real keys.
# - Mock is the default provider; these keys are used only when a backend live
#   provider mode is explicitly enabled (opt-in), never via the frontend.
# - GOOGLE_API_KEY enables the opt-in Gemini provider.
# - OPENAI_API_KEY enables the opt-in OpenAI provider. OpenAI usage is paid and
#   live smoke tests require an explicit paid-use acknowledgement.
# Internal knobs (POA_LLM_MODE / POA_LLM_PROVIDER / POA_LLM_MODEL / timeouts /
# retries / token budget / rate-limit fallback / POA_LLM_LIVE_TESTS /
# POA_P36_LIVE_LANES / POA_EDGAR_REPORT_EVIDENCE_MODE /
# POA_FMP_FUNDAMENTALS_MODE) are
# backend defaults and test-only configuration; they are intentionally not part
# of normal setup. See docs/claude-e-agentic/LLM_PROVIDER_SMOKE_TEST.md.
GOOGLE_API_KEY=replace_with_google_gemini_api_key
OPENAI_API_KEY=replace_with_openai_api_key
SEC_EDGAR_USER_AGENT=replace_with_descriptive_sec_contact_user_agent
